   </license>

   <requires>
      <import feature="org.palladiosimulator.analyzer.slingshot.feature" version="1.0.0" match="greaterOrEqual"/>
      <import feature="org.palladiosimulator.analyzer.slingshot.extension.pcm.core" version="1.0.0" match="greaterOrEqual"/>
      <import feature="org.palladiosimulator.analyzer.slingshot.extension.monitoring.feature" version="1.0.0" match="greaterOrEqual"/>
   </requires>

   <plugin
         id="org.palladiosimulator.analyzer.slingshot.mcp"
         download-size="0"
         install-size="0"
         version="0.0.0"
         unpack="false"/>

</feature>
